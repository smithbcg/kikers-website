<div class="race-rule"></div>
<section class="finalcta"><div class="wrap">
  <div><h2>Got a car to sell? Let's get you paid.</h2><p>Fair offer, free towing, same-day pickup. Pensacola's yard for 25 years.</p></div>
  <div class="grp"><a class="btn btn--amber btn--lg" href="tel:{{ siteSettings.phoneNumber|replace({"-": ""}) }}"><span class="ic">📞</span>Call {{ siteSettings.phoneNumber }}</a><a class="btn btn--outline-light btn--lg" href="#offer-form">Get an Offer</a></div>
</div></section>

