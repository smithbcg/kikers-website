        <div class="addr-row"><div class="a1">{{ siteSettings.streetAddress }}</div><a class="a2" href="tel:{{ siteSettings.phoneNumber|replace({"-": ""}) }}">{{ siteSettings.phoneNumber }}</a>
          <div class="visit-actions"><a class="btn btn--filled" href="contact.html"><span class="ic">📍</span>Get Directions</a><a class="btn btn--outline" href="tel:{{ siteSettings.phoneNumber|replace({"-": ""}) }}">Call the Yard</a></div>
        </div>
      </div>
      <div class="hours">
        <h3>Hours</h3>
        <table class="htable" id="htable">
          <tr data-d="1"><td class="day">Monday</td><td class="hrs">9:00 – 4:30</td></tr>
          <tr data-d="2"><td class="day">Tuesday</td><td class="hrs">9:00 – 4:30</td></tr>
          <tr data-d="3"><td class="day">Wednesday</td><td class="hrs">9:00 – 4:30</td></tr>
          <tr data-d="4"><td class="day">Thursday</td><td class="hrs">9:00 – 4:30</td></tr>
