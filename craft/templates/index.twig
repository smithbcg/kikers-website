<body id="top">

{% include '_partials/site-header' with { thirdHref: '#how', ctaLabel: 'Get My Offer', ctaHref: '#offer-form', drawerCtaLabel: 'Get My Cash Offer' } %}

<!-- HERO -->
<section class="hero" id="offer">
  <div class="hero-photo hero-photo--yard" aria-hidden="true"></div>
  <div class="wrap"><div class="hero-grid">
    <div>
      <div class="h-tags"><span class="eyebrow on-ink">Pensacola, FL</span><span class="chiplet">Est. 2001 · 3rd generation</span><span class="chiplet">Open Mon-Fri 9-4:30; Sat 8-2</span></div>
      <h1>Built in the <em>yard.</em></h1>
      <p class="lede">Three generations on the same Pensacola ground since 1972. We buy your car for cash — running or not — and handle the towing, paperwork, and required reporting. Done by the book. Or bring your tools and pull your own parts.</p>
      <div class="cta-row"><a class="btn btn--amber btn--lg" href="#offer-form"><span class="ic">⚡</span>Get a Cash Offer</a><a class="btn btn--outline-light btn--lg" href="u-pull-parts.html">Find a Part</a></div>
    </div>
    <div class="offer-card" id="offer-form">
      <div class="ohead"><h2>Cash for your car</h2><span class="avail"><span class="dot pulse"></span>Fast</span></div>
      <div class="sub">A few details — no haggling.</div>
      <form class="qf" onsubmit="return submitOffer(event)">
        <input type="text" placeholder="Year, make &amp; model" required>
        <select required><option value="" selected disabled>Condition</option><option>Runs &amp; drives</option><option>Starts only</option><option>Won't start</option><option>Inoperable</option><option>Wrecked / junk</option></select>
        <input type="tel" placeholder="Phone" required>
        <button class="btn btn--filled btn--block" type="submit"><span class="ic">⚡</span>Get My Cash Offer</button>
      </form>
      <div class="fine">Free &amp; no obligation</div>
    </div>
  </div></div>
</section>
<div class="hazard"></div>

<!-- CHROME STAT PLATES -->
<section class="sec tight">
  <div class="wrap"><div class="plates">
    <div class="plate"><div><div class="n" style="color:var(--red)">25</div><div class="l">Years Serving</div></div></div>
    <div class="plate"><div><div class="n" style="color:var(--ink)">3</div><div class="l">Generations</div></div></div>
    <div class="plate"><div><div class="n" style="color:var(--ink)">Free</div><div class="l">Towing</div></div></div>
    <div class="plate"><div><div class="n" style="color:var(--amber)">6<span>days</span></div><div class="l">Open Each Week</div></div></div>
  </div></div>
</section>

<!-- VALUES -->
<section class="values-band">
  <div class="wrap"><div class="values-layout">
    <div><span class="eyebrow">How We Work</span><h2>Built into every deal</h2></div>
    <div class="values-grid">
      <div class="value-item"><i data-lucide="wrench" aria-hidden="true"></i><b>Own It</b><span>See it. Handle it.</span></div>
      <div class="value-item"><i data-lucide="badge-check" aria-hidden="true"></i><b>Do Right</b><span>Fair and by the book.</span></div>
      <div class="value-item"><i data-lucide="gauge" aria-hidden="true"></i><b>Outwork It</b><span>Move when it matters.</span></div>
      <div class="value-item"><i data-lucide="handshake" aria-hidden="true"></i><b>Back Each Other</b><span>Family, crew, community.</span></div>
      <div class="value-item"><i data-lucide="shield-check" aria-hidden="true"></i><b>Watch Out</b><span>Everyone goes home safe.</span></div>
    </div>
  </div></div>
</section>

<!-- SERVICES -->
<section class="sec" style="padding-top:24px">
  <div class="wrap">
    <div class="sec-head"><span class="eyebrow">Choose Your Path</span><h2>What can we help you do?</h2><p>Sell a vehicle, pull your own part, or let our crew locate and pull it for you.</p></div>
    <div class="service-focus">
      <article class="service-primary">
        <div class="service-icon"><i data-lucide="badge-dollar-sign" aria-hidden="true"></i></div>
        <div><span class="k">FASTEST WAY TO SELL</span><h3>Cash for your car</h3><p>Running or not, get a fair offer without the listing, haggling, or towing bill. We pick it up and handle the required paperwork.</p>
          <ul class="service-points"><li><i data-lucide="check" aria-hidden="true"></i>Free towing</li><li><i data-lucide="check" aria-hidden="true"></i>Same-day available</li><li><i data-lucide="check" aria-hidden="true"></i>No obligation</li></ul>
          <a class="btn btn--filled btn--lg" href="#offer-form"><i data-lucide="zap" aria-hidden="true"></i>Get My Cash Offer</a>
        </div>
      </article>
      <div class="service-secondary-stack">
        <article class="service-secondary"><div class="service-icon"><i data-lucide="wrench" aria-hidden="true"></i></div><div><h3>Pull your own parts</h3><p>Bring your tools, find the row, and save with self-service pricing.</p><a class="arrow" href="u-pull-parts.html">Search the yard <span class="x">→</span></a></div></article>
        <article class="service-secondary"><div class="service-icon"><i data-lucide="package-search" aria-hidden="true"></i></div><div><h3>We pull it for you</h3><p>Tell us what you need. We locate, pull, vet, and prepare it for pickup or shipping.</p><a class="arrow" href="full-service-parts.html">Request a part <span class="x">→</span></a></div></article>
      </div>
    </div>
  </div>
</section>

<!-- LEAD FORM -->
<section class="sec lead">
  <div class="wrap"><div class="split2">
    <div>
      <span class="eyebrow">Cash for Cars</span>
      <h2 style="font-size:clamp(26px,3.4vw,36px);margin:8px 0;font-style:italic">Sell your vehicle for cash</h2>
      <p style="color:var(--text-2);font-size:17px;margin:0 0 24px;max-width:48ch">Any make, model, or condition. Fair offer fast, free towing, and we handle the paperwork and required reporting — done by the book.</p>
      <div class="form-card">
        <form onsubmit="return submitOffer(event)">
          <div class="grid2" style="margin-bottom:16px"><div class="field"><label>Year</label><input placeholder="2012" required></div><div class="field"><label>Make</label><input placeholder="Honda" required></div></div>
          <div class="grid2" style="margin-bottom:16px"><div class="field"><label>Model</label><input placeholder="Civic" required></div><div class="field"><label>Condition</label><select required><option value="" selected disabled>Select…</option><option>Runs &amp; drives</option><option>Starts only</option><option>Won't start</option><option>Inoperable</option><option>Wrecked</option></select></div></div>
          <div class="grid2" style="margin-bottom:20px"><div class="field"><label>Name</label><input placeholder="First &amp; last" required></div><div class="field"><label>Phone</label><input type="tel" placeholder="(850) 000-0000" required></div></div>
          <button class="btn btn--filled btn--block btn--lg" type="submit"><span class="ic">⚡</span>Get My Cash Offer</button>
        </form>
      </div>
    </div>
    <aside class="lead-aside">
      <div class="ph ph--4x5 ph--dark"><div class="ph-in"><span class="ph-cam">📷</span><span class="ph-kick">PHOTO — THE HANDOFF</span><span class="ph-desc">Keys handed over, a tow truck loading, or cash in hand. Real, daylight.</span></div></div>
      <ul class="verified">
        <li><span class="vc">✓</span><span><b>Same-day or scheduled pickup</b> — you choose the time.</span></li>
        <li><span class="vc">✓</span><span><b>Free towing &amp; paperwork handled</b> — including required NMVTIS reporting.</span></li>
        <li><span class="vc">✓</span><span><b>Recycled the right way</b> — good parts put back to work, metals recovered.</span></li>
      </ul>
    </aside>
  </div></div>
</section>

<!-- NEW ARRIVALS -->
<section class="sec" id="inventory">
  <div class="wrap">
    <div class="sec-head"><div class="row-between"><div><span class="eyebrow">Just In</span><h2 style="font-style:italic">This week in the yard</h2></div><a class="btn btn--text" href="u-pull-parts.html">View all inventory →</a></div></div>
    <div class="fcards">
      <div class="feature-card"><div class="img"><span class="ph-mini">PHOTO: F-150</span></div><span class="flag">JUST IN</span><div class="fc-txt"><span class="avail" style="margin-bottom:8px"><span class="dot pulse"></span>In the yard now</span><h4>2011 Ford F-150</h4><span class="km">ROW 22 · ARRIVED TODAY</span></div></div>
      <div class="feature-card"><div class="img"><span class="ph-mini">PHOTO: Civic</span></div><span class="flag">JUST IN</span><div class="fc-txt"><h4>2012 Honda Civic</h4><span class="km">ROW 14 · 1.8L · AUTO</span></div></div>
      <div class="feature-card"><div class="img"><span class="ph-mini">PHOTO: Silverado</span></div><span class="flag">HOT PART</span><div class="fc-txt"><span class="km">ENGINE · 5.3L V8</span><h4>'08 Silverado</h4></div></div>
      <div class="feature-card"><div class="img"><span class="ph-mini">PHOTO: cash</span></div><span class="flag amber">CASH</span><div class="fc-txt"><span class="km">PENSACOLA · 850</span><h4>We buy your ride today</h4></div></div>
    </div>
    <div class="inventory-detail">
      <div class="list">
        <div class="li"><div class="av">F</div><div class="tx"><div class="t1">2011 Ford F-150</div><div class="t2">Arrived today · Crew cab</div></div><div class="meta">ROW 22</div></div>
        <div class="li"><div class="av steel">H</div><div class="tx"><div class="t1">2012 Honda Civic</div><div class="t2">Engine pulled · 1.8L</div></div><div class="meta">ROW 14</div></div>
        <div class="li"><div class="av">C</div><div class="tx"><div class="t1">2008 Chevy Silverado</div><div class="t2">Body straight · 5.3L V8</div></div><div class="meta">ROW 07</div></div>
        <div class="li"><div class="av steel">T</div><div class="tx"><div class="t1">2010 Toyota Sequoia</div><div class="t2">4WD · 4.7L V8</div></div><div class="meta">ROW 31</div></div>
      </div>
      <div class="spec-card" style="max-width:560px">
        <div class="sc-top"><div><h4>2012 Honda Civic LX</h4><span class="avail" style="margin-top:6px"><span class="dot"></span>Available now</span></div><span class="row-tag">ROW 14</span></div>
        <div class="spec-grid">
          <div class="cell"><div class="ic">⛽</div><span class="lab">Engine</span><span class="val">1.8L</span></div>
          <div class="cell"><div class="ic">⏱</div><span class="lab">Mileage</span><span class="val">112k</span></div>
          <div class="cell"><div class="ic">⚙</div><span class="lab">Trans</span><span class="val">Auto</span></div>
          <div class="cell"><div class="ic">📅</div><span class="lab">Arrived</span><span class="val">Jun 12</span></div>
        </div>
        <div class="sc-foot"><span class="hint">Parts priced in-yard</span><a class="btn btn--amber btn--sm" href="contact.html">Get directions</a></div>
      </div>
    </div>
  </div>
</section>

<div class="race-rule"></div>

<!-- HOW IT WORKS -->
<section class="sec" id="how" style="background:var(--surface-3)">
  <div class="wrap">
    <div class="sec-head center"><span class="eyebrow">How It Works</span><h2>Cash for cars in four steps</h2><p>Whoever responds first usually wins — so when you reach out, we move.</p></div>
    <div class="stepper">
      <div class="step done"><div class="node">1</div><div class="lab">Details</div><div class="sub">Call or send your vehicle info.</div></div>
      <div class="step done"><div class="node">2</div><div class="lab">Offer</div><div class="sub">A fair cash number, fast.</div></div>
      <div class="step done"><div class="node">3</div><div class="lab">Pickup</div><div class="sub">Same-day or on your schedule.</div></div>
      <div class="step"><div class="node">4</div><div class="lab">Paid</div><div class="sub">Cash in hand, paperwork handled.</div></div>
    </div>
    <div style="text-align:center;margin-top:38px"><a class="btn btn--filled btn--lg" href="#offer-form"><span class="ic">⚡</span>Get My Cash Offer</a></div>
  </div>
</section>

<!-- STORY -->
<section class="sec story" id="story">
  <div class="wrap"><div class="story-grid">
    <div>
      <span class="eyebrow on-ink">Our Story</span>
      <h2>25 years. <em>Three generations.</em></h2>
      <p class="lede">The property's been in the family since 1972. We reopened as Kiker's U-Pull-It in 2001. Hunter was 14, breaking down aluminum wheels and setting cars on heavy stands in the sand and dirt under the Pensacola sun. He learned the yard from the ground up. That history is our edge; nobody around here has it.</p>
      <p class="body">Sell us your car and it isn't the end of the road. The parts that still have life keep another local family driving instead of going straight to the crusher. The rest is recycled the right way, and you get a fair deal for it.</p>
      <a class="btn btn--outline-light" href="about.html" style="margin-top:6px">Read our story →</a>
    </div>
    <div class="plates">
      <div class="plate dark"><div><div class="n">1972</div><div class="l">Land Bought</div></div></div>
      <div class="plate dark"><div><div class="n">2001</div><div class="l">Reopened</div></div></div>
      <div class="plate dark"><div><div class="n" style="color:var(--amber)">3rd</div><div class="l">Generation</div></div></div>
      <div class="plate dark"><div><div class="n" style="color:var(--red)">25</div><div class="l">Years</div></div></div>
    </div>
  </div></div>
</section>

<!-- REVIEWS -->
<section class="sec">
  <div class="wrap">
    <div class="sec-head center"><span class="eyebrow">What Customers Say</span><div class="agg"><span class="score">{{ siteSettings.googleRating }}</span><span class="stars">★★★★☆</span><span class="from">based on {{ siteSettings.googleReviewCount }} Google reviews</span></div></div>
    <div class="rcards">
      <div class="rcard"><div class="stars">★★★★★</div><p>"Called in the morning, fair price over the phone, picked it up that same afternoon. Cash in hand, no runaround."</p><div class="who"><span class="name">Marcus T. · Pensacola</span><span class="date">2 WKS</span></div></div>
      <div class="rcard"><div class="stars">★★★★★</div><p>"Yard's organized by rows so I found my part fast. Way cheaper than new, and the staff knew their stuff."</p><div class="who"><span class="name">Dana R. · Pace</span><span class="date">1 MO</span></div></div>
      <div class="rcard"><div class="stars">★★★★★</div><p>"It was my late husband's car. They were kind, handled everything, and I felt good knowing it'd be recycled right."</p><div class="who"><span class="name">Patricia L. · Milton</span><span class="date">1 MO</span></div></div>
    </div>
  </div>
</section>

<!-- LOCATION -->
