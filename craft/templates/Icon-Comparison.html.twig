<script src="https://cdn.jsdelivr.net/npm/lucide@latest/dist/umd/lucide.min.js"></script>
<script>
var ICONS=[
  {label:"Phone / call",ph:"phone",ti:"phone",lu:"phone"},
  {label:"Speed / fast",ph:"lightning",ti:"bolt",lu:"zap"},
  {label:"Tow truck",ph:"truck",ti:"truck",lu:"truck"},
  {label:"Parts / wrench",ph:"wrench",ti:"tool",lu:"wrench"},
  {label:"Cash / offer",ph:"currency-dollar",ti:"currency-dollar",lu:"badge-dollar-sign"},
  {label:"Recycle",ph:"recycle",ti:"recycle",lu:"recycle"},
  {label:"Done right / legit",ph:"shield-check",ti:"shield-check",lu:"shield-check"},
  {label:"Hours / clock",ph:"clock",ti:"clock",lu:"clock"},
  {label:"Location / map",ph:"map-pin",ti:"map-pin",lu:"map-pin"},
  {label:"Car / vehicle",ph:"car",ti:"car",lu:"car"},
  {label:"Check",ph:"check-circle",ti:"circle-check",lu:"circle-check"},
  {label:"How it works / gear",ph:"gear",ti:"settings",lu:"settings"}
];
var tb=document.getElementById('grid');
ICONS.forEach(function(o){
  var tr=document.createElement('tr');
  tr.innerHTML='<th>'+o.label+'</th>'+
    '<td><span class="ico"><i class="ph-bold ph-'+o.ph+'"></i></span><div class="cap">ph-'+o.ph+'</div></td>'+
    '<td><span class="ico"><i class="ti ti-'+o.ti+'"></i></span><div class="cap">ti-'+o.ti+'</div></td>'+
    '<td><span class="ico"><i data-lucide="'+o.lu+'"></i></span><div class="cap">'+o.lu+'</div></td>';
  tb.appendChild(tr);
});
if(window.lucide&&lucide.createIcons)lucide.createIcons();
// offline hint: if Phosphor font didn't load, the glyph box width stays tiny
setTimeout(function(){
  var probe=document.querySelector('.cgrid .ph-phone, .cgrid [class*="ph-"]');
  // best-effort; if lucide failed too, show note
  if(!document.querySelector('svg.lucide')){document.getElementById('offline').style.display='block';}
},1200);
</script>
