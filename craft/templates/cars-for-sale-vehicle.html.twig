          <div class="r"><span>Engine</span><b>1.5L Turbo</b></div>
          <div class="r"><span>Trans</span><b>Automatic</b></div>
          <div class="r"><span>Drivetrain</span><b>FWD</b></div>
          <div class="r"><span>Condition</span><b>Runs &amp; drives</b></div>
        </div>
