    <div class="ec"><h3>Questions on this Civic?</h3><p>Ask us anything — or check it's still available. We'll get right back to you.</p></div>
    <form onsubmit="return submitMsg(event)">
      <div class="full"><input type="text" placeholder="Your question (e.g. is it still available?)" required></div>
      <input type="text" placeholder="Your name" required>
      <input type="tel" placeholder="Phone" required>
      <button class="btn btn--filled btn--block full" type="submit"><span class="ic">→</span>Send (re: Stock #C-1842)</button>
    </form>
  </div>
</section>

