<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
{% include '_partials/seo' with { legacyTemplate: 'thank-you.html' } %}
<meta name="robots" content="noindex">
<link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Saira:ital,wght@0,500;0,600;0,700;0,800;1,600;1,700;1,800&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="kikers.css?v=20260713-craftcms3">
</head>
<body id="top">

{% include '_partials/site-header' with { thirdNav: 'none', ctaLabel: 'Call Us', ctaHref: 'phone', drawerCtaLabel: 'Call ' ~ siteSettings.phoneNumber } %}

<section class="confirm">
  <div>
    <div class="seal">✓</div>
    <span class="eyebrow" style="justify-content:center">Request Received</span>
    <h1 style="margin-top:8px">We've got it — talk soon.</h1>
    <p>Thanks for reaching out to Kiker's. We'll call or text you back fast, usually within minutes during business hours. Want to skip the wait?</p>
    <div style="display:flex;gap:12px;flex-wrap:wrap;justify-content:center">
      <a class="btn btn--filled btn--lg" href="tel:{{ siteSettings.phoneNumber|replace({"-": ""}) }}"><span class="ic">📞</span>Call {{ siteSettings.phoneNumber }}</a>
      <a class="btn btn--outline btn--lg" href="index.html">Back to Home</a>
    </div>
    <div style="margin-top:26px" class="plates" >
      <div class="plate"><div><div class="n" style="color:var(--red)">Same-Day</div><div class="l">Pickup &amp; Cash</div></div></div>
      <div class="plate"><div><div class="n" style="color:var(--ink)">Free</div><div class="l">Towing</div></div></div>
      <div class="plate"><div><div class="n" style="color:var(--ink)">Handled</div><div class="l">Paperwork</div></div></div>
      <div class="plate"><div><div class="n" style="color:var(--amber)">25</div><div class="l">Years</div></div></div>
    </div>
  </div>
</section>

<div class="ecostrip"><div class="wrap"><span class="ic">♻️</span><span class="t">Every vehicle is recycled the right way — good parts reused, metals recovered, fluids handled properly.</span></div></div>

{% include '_partials/site-footer' %}
<div class="toast-host" id="toastHost"></div>
<script src="kikers.js?v=20260713-craftcms3" defer></script>
</body>
</html>
