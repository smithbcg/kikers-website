<style>
/* ===== DESIGN TOKENS (Kiker's Site Style Guide) ===== */
:root{
  --red:#DC161F;--red-700:#B4101A;--red-800:#8C0C14;--red-wash:#FDEDEE;
  --amber:#F6A100;--amber-300:#FFC74D;--amber-600:#D98200;--amber-wash:#FFF4DC;
  --ink:#0B0611;--white:#FFFFFF;
  --bg:#F4F4F6;--surface-1:#FFFFFF;--surface-3:#EFEFF1;--blue-wash:#F0F4F8;
  --text:#0B0611;--text-2:#55555B;--text-3:#86868D;
  --line:#E5E5E8;--line-2:#D8D8DC;--line-strong:#BEBEC4;--steel-700:#72767B;
  --green:#1E9E57;--green-600:#178A4A;--green-700:#0F6E3B;--green-on-wash:#0F6E3B;--green-wash:#E4F5EC;--green-line:rgba(15,110,59,.22);
  --grad-ink:linear-gradient(160deg,#0B0611,#1A1719);--grad-red:linear-gradient(135deg,#DC161F,#8C0C14);--grad-chrome:linear-gradient(135deg,#E3E6E8,#9A9FA4 55%,#D7DBDE);
  --r-xs:2px;--r-sm:3px;--r-md:4px;--r-lg:6px;--r-pill:100px;
  --e1:0 1px 2px rgba(11,6,17,.08);--e2:0 8px 20px rgba(11,6,17,.10);--e3:0 20px 48px rgba(11,6,17,.16);--glow-red:0 0 0 1px rgba(220,22,31,.25),0 10px 28px rgba(220,22,31,.20);
  --display:'Saira',system-ui,sans-serif;--body:'Inter',system-ui,sans-serif;--mono:'JetBrains Mono',ui-monospace,monospace;--maxw:1200px;
}
*{box-sizing:border-box}
html{scroll-behavior:smooth}
@media (prefers-reduced-motion:reduce){html{scroll-behavior:auto}*{animation-duration:.001ms!important;transition-duration:.001ms!important}}
body{margin:0;background:var(--bg);color:var(--text);font-family:var(--body);font-size:16px;line-height:1.6;-webkit-font-smoothing:antialiased}
a{color:inherit;text-decoration:none}img,svg{max-width:100%}
h1,h2,h3,h4{margin:0;font-family:var(--display);font-weight:800;letter-spacing:-.01em;line-height:1.05;text-transform:uppercase}
:focus-visible{outline:2px solid var(--amber);outline-offset:2px;border-radius:var(--r-xs)}
::selection{background:var(--red);color:#fff}
.wrap{max-width:var(--maxw);margin:0 auto;padding:0 24px}
.eyebrow{font-family:var(--body);font-weight:600;font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--red);display:inline-flex;align-items:center;gap:8px}
.eyebrow::before{content:"";width:18px;height:2px;background:var(--red)}
.eyebrow.on-ink{color:var(--amber-300)}.eyebrow.on-ink::before{background:var(--amber)}
.mono{font-family:var(--mono)}
.race-rule{height:14px;width:100%;background-color:#fff;background-image:linear-gradient(45deg,var(--ink) 25%,transparent 25%),linear-gradient(-45deg,var(--ink) 25%,transparent 25%),linear-gradient(45deg,transparent 75%,var(--ink) 75%),linear-gradient(-45deg,transparent 75%,var(--ink) 75%);background-size:14px 14px;background-position:0 0,0 7px,7px -7px,-7px 0;border-top:2px solid var(--red);border-bottom:2px solid var(--red)}

/* photo placeholder */
.ph{position:relative;border-radius:var(--r-lg);overflow:hidden;border:1.5px dashed var(--line-strong);background:repeating-linear-gradient(45deg,#fafafb 0 10px,#f1f1f4 10px 20px);display:grid;place-items:center;text-align:center}
.ph--16x9{aspect-ratio:16/9}.ph--4x3{aspect-ratio:4/3}.ph--1x1{aspect-ratio:1/1}.ph--dark{border-color:rgba(255,255,255,.22);background:var(--grad-ink)}
.ph-in{padding:16px;display:flex;flex-direction:column;gap:5px;align-items:center;max-width:94%}
.ph-cam{font-size:22px;opacity:.85}.ph-kick{font-family:var(--mono);font-size:10px;letter-spacing:.16em;color:var(--amber-600)}.ph--dark .ph-kick{color:var(--amber-300)}
.ph-desc{font-size:12.5px;color:var(--text-2);line-height:1.4;font-weight:500}.ph--dark .ph-desc{color:rgba(255,255,255,.86)}
.ph-spec{font-family:var(--mono);font-size:10.5px;color:var(--text-3)}.ph--dark .ph-spec{color:rgba(255,255,255,.5)}
.ph-tag{position:absolute;left:16px;bottom:16px;z-index:4;max-width:330px;text-align:left;background:rgba(11,6,17,.74);border:1.5px dashed rgba(255,255,255,.35);border-radius:var(--r-md);padding:9px 12px;color:#fff}
.ph-tag .k{display:block;font-family:var(--mono);font-size:10px;letter-spacing:.14em;color:var(--amber-300);margin-bottom:3px}
.ph-tag .d{font-size:12px;line-height:1.4}.ph-tag .s{display:block;font-family:var(--mono);font-size:10px;color:rgba(255,255,255,.6);margin-top:4px}

/* buttons */
.btn{--bg:transparent;--fg:var(--text);--bd:transparent;font-family:var(--display);font-weight:700;font-style:italic;text-transform:uppercase;letter-spacing:.04em;font-size:14px;display:inline-flex;align-items:center;justify-content:center;gap:8px;cursor:pointer;padding:0 20px;height:48px;border-radius:var(--r-md);border:1.5px solid var(--bd);background:var(--bg);color:var(--fg);transition:transform .07s,background .15s,box-shadow .15s,border-color .15s;white-space:nowrap}
.btn:active{transform:translateY(1px)}.btn .ic{font-style:normal;font-weight:700;font-size:16px;line-height:1}
.btn--filled{--bg:var(--red);--fg:#fff;--bd:var(--red);box-shadow:var(--e1)}.btn--filled:hover{--bg:var(--red-700);--bd:var(--red-700);box-shadow:var(--glow-red)}
.btn--amber{--bg:var(--amber);--fg:#3a2600;--bd:var(--amber)}.btn--amber:hover{--bg:var(--amber-600);--bd:var(--amber-600)}
.btn--outline{--bg:transparent;--fg:var(--text);--bd:var(--line-strong)}.btn--outline:hover{--bd:var(--ink);--bg:rgba(11,6,17,.04)}
.btn--outline-light{--bg:transparent;--fg:#fff;--bd:rgba(255,255,255,.55)}.btn--outline-light:hover{--bd:#fff;--bg:rgba(255,255,255,.08)}
.btn--sm{height:40px;font-size:13px;padding:0 16px}.btn--lg{height:54px;font-size:15px;padding:0 28px}.btn--block{display:flex;width:100%}
.dot{width:8px;height:8px;border-radius:50%;background:var(--green);box-shadow:0 0 0 3px rgba(30,158,87,.22);flex:0 0 auto}
.src{font-size:12px;color:var(--text-3)}.src a{color:var(--text-2);text-decoration:underline}.src a:hover{color:var(--red)}
.tagph{display:inline-block;font-family:var(--mono);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--amber-600);background:var(--amber-wash);border:1px solid var(--amber-300);border-radius:var(--r-xs);padding:2px 7px;vertical-align:middle}

/* eco badge (reusable) */
.ecobadge{display:inline-flex;align-items:center;gap:7px;font-weight:700;font-size:12px;color:var(--green-700);background:var(--green-wash);border:1px solid var(--green-line);border-radius:var(--r-pill);padding:5px 12px}
.ecobadge.on-ink{background:rgba(30,158,87,.16);border-color:rgba(86,208,138,.4);color:#8fe3b3}
.ecostrip{background:var(--green-wash);border-top:1px solid var(--green-line);border-bottom:1px solid var(--green-line)}
.ecostrip .wrap{padding:16px 24px;display:flex;align-items:center;justify-content:center;gap:12px;text-align:center;flex-wrap:wrap}
.ecostrip .ic{font-size:22px;color:var(--green-700)}.ecostrip .t{font-size:15px;color:var(--green-700);font-weight:600}

/* utility strip + nav */
.ustrip{background:var(--ink);color:rgba(255,255,255,.86);font-size:13px}
.ustrip .wrap{display:flex;align-items:center;justify-content:space-between;height:38px;gap:16px}
.ustrip a{color:#fff;font-weight:500}.ustrip .sep{opacity:.4;margin:0 10px}
.ustrip .u-left,.ustrip .u-right{display:flex;align-items:center;white-space:nowrap}.ustrip .u-right{color:var(--amber-300)}
@media(max-width:760px){.ustrip .u-left .addr,.ustrip .u-right .txt{display:none}.ustrip .wrap{justify-content:center;gap:8px}}
.nav{position:sticky;top:0;z-index:60;height:66px;background:#fff;border-bottom:1px solid transparent;transition:border-color .2s,box-shadow .2s,backdrop-filter .2s}
.nav.scrolled{border-bottom-color:var(--line);box-shadow:var(--e1);background:rgba(255,255,255,.95);backdrop-filter:blur(8px)}
.nav .wrap{display:flex;align-items:center;height:66px;gap:18px}
.brand{display:flex;align-items:center;gap:11px}
.brand-logo{line-height:0;gap:0}
.nav .brand-logo{width:168px;max-width:48vw}
.brand-logo-img{display:block;width:100%;height:auto;object-fit:contain}
.ftr .brand-logo{width:250px;max-width:100%;background:#fff;border-radius:12px;padding:8px 10px;box-shadow:0 10px 24px rgba(0,0,0,.18)}
.brand .shield{width:40px;height:40px;border-radius:var(--r-sm);background:var(--grad-red);display:grid;place-items:center;font-family:var(--display);font-style:italic;font-weight:800;color:#fff;font-size:23px;box-shadow:var(--e1)}
.brand .wm{font-family:var(--display);font-style:italic;font-weight:800;font-size:20px;letter-spacing:-.02em;line-height:.92}
.brand .wm span{display:block;font-size:9px;letter-spacing:.30em;font-style:normal;font-weight:700;color:var(--red)}
.nav .spacer{flex:1}.nav .links{display:none;align-items:center;gap:26px}
.nav .links a{font-size:15px;font-weight:500;color:var(--text)}.nav .links a:hover{color:var(--red)}.nav .links a.cur{color:var(--red);font-weight:600}
.nav .menu{background:none;border:1px solid var(--line-2);color:var(--text);width:42px;height:42px;border-radius:var(--r-md);font-size:18px;cursor:pointer;display:grid;place-items:center}
@media(min-width:1040px){.nav .links{display:flex}.nav .menu{display:none}}
.drawer{position:fixed;inset:0 0 0 auto;width:min(320px,86vw);background:#fff;z-index:90;transform:translateX(100%);transition:transform .24s cubic-bezier(.2,.8,.2,1);box-shadow:var(--e3);padding:24px;display:flex;flex-direction:column;gap:6px}
.drawer.open{transform:translateX(0)}
.drawer a{padding:13px 10px;border-bottom:1px solid var(--line);font-family:var(--display);font-style:italic;font-weight:700;text-transform:uppercase;font-size:16px}
.drawer .btn{margin-top:16px}
.scrim{position:fixed;inset:0;background:rgba(5,3,7,.5);z-index:85;opacity:0;visibility:hidden;transition:opacity .2s}.scrim.open{opacity:1;visibility:visible}
.crumbs{background:#fff;border-bottom:1px solid var(--line)}.crumbs .wrap{padding:11px 24px;font-size:13px;color:var(--text-3)}.crumbs a{color:var(--text-2)}.crumbs a:hover{color:var(--red)}.crumbs .sep{margin:0 8px;color:var(--line-strong)}

/* hero */
.hero{position:relative;overflow:hidden;color:#fff;background:var(--grad-ink)}
.hero .hero-photo{position:absolute;inset:0;z-index:0;background:linear-gradient(120deg,#211c24,#15121a 60%,#241b1d)}
.hero::after{content:"";position:absolute;inset:0;z-index:1;pointer-events:none;background:linear-gradient(90deg,rgba(11,6,17,.92),rgba(11,6,17,.74) 45%,rgba(11,6,17,.32)),radial-gradient(700px 360px at 92% -10%,rgba(220,22,31,.30),transparent 60%)}
.hero .wrap{position:relative;z-index:2;padding:58px 24px 70px}
.hero-grid{display:grid;grid-template-columns:1.12fr .88fr;gap:48px;align-items:center}
.hero .h-tags{display:flex;flex-wrap:wrap;gap:12px;align-items:center;margin-bottom:18px}
.chiplet{font-family:var(--mono);font-size:12px;font-weight:500;color:rgba(255,255,255,.82);border:1px solid rgba(255,255,255,.2);padding:5px 11px;border-radius:var(--r-pill)}
.hero h1{font-size:clamp(34px,5vw,56px);font-style:italic;line-height:.95;letter-spacing:-.5px}
.hero h1 em{color:var(--red);font-style:italic}
.hero .lede{max-width:54ch;color:rgba(255,255,255,.84);font-size:17px;margin:18px 0 24px}
.hero .cta-row{display:flex;flex-wrap:wrap;gap:14px;align-items:center}
.hero .areas{margin-top:20px;font-size:13px;color:rgba(255,255,255,.66)}.hero .areas b{color:#fff}
.offer-card{position:relative;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.16);border-radius:var(--r-lg);padding:24px;backdrop-filter:blur(6px)}
.offer-card h2{font-style:italic;font-size:22px;color:#fff;margin-bottom:4px;text-transform:uppercase}
.offer-card .sub{color:rgba(255,255,255,.72);font-size:13px;margin-bottom:16px}
.offer-card .qf{display:grid;grid-template-columns:1fr 1fr;gap:12px}.offer-card .qf .full{grid-column:1 / -1}
.offer-card label{font-size:11px;font-weight:600;letter-spacing:.04em;text-transform:uppercase;color:rgba(255,255,255,.66);margin-bottom:5px;display:block}
.offer-card input,.offer-card select{width:100%;height:46px;background:rgba(255,255,255,.08);border:1.5px solid rgba(255,255,255,.2);border-radius:var(--r-md);color:#fff;padding:0 12px;font-family:var(--body);font-size:14px;outline:none}
.offer-card input::placeholder{color:rgba(255,255,255,.55)}.offer-card select{color:rgba(255,255,255,.62)}.offer-card option{color:#111}
.offer-card input:focus,.offer-card select:focus{border-color:var(--amber)}.offer-card .btn{margin-top:6px}.offer-card .fine{margin-top:10px;text-align:center;color:rgba(255,255,255,.58);font-size:12px}
@media(max-width:900px){.hero-grid{grid-template-columns:1fr;gap:32px}.hero .wrap{padding:42px 24px 50px}.hero::after{background:linear-gradient(180deg,rgba(11,6,17,.72),rgba(11,6,17,.92)),radial-gradient(540px 300px at 50% -20%,rgba(220,22,31,.32),transparent 62%)}}

/* trust bar */
.trustbar{background:var(--surface-3);border-bottom:1px solid var(--line)}
.trustbar .wrap{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;padding:24px}
.trustbar .item{text-align:center;display:flex;flex-direction:column;align-items:center;gap:3px}
.trustbar .item .ic{font-size:22px;margin-bottom:3px}
.trustbar .item .n{font-family:var(--display);font-style:italic;font-weight:800;font-size:20px}
.trustbar .item .l{font-size:12.5px;color:var(--text-2)}
@media(max-width:680px){.trustbar .wrap{grid-template-columns:repeat(2,1fr);gap:22px;padding:28px 24px}}

/* sections */
section{scroll-margin-top:80px}
.sec{padding:64px 0}
.sec-head{margin-bottom:28px}
.sec-head.center{text-align:center;display:flex;flex-direction:column;align-items:center}
.sec-head h2{font-size:clamp(24px,3.1vw,33px);margin:8px 0}
.sec-head p{margin:0;max-width:64ch;color:var(--text-2);font-size:17px}.sec-head.center p{margin:0 auto}
.lead-p{font-size:17px;color:var(--text-2);max-width:68ch}.lead-p b{color:var(--text)}

/* what we buy */
.buy-grid{display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:start}
.taglist{display:flex;flex-wrap:wrap;gap:10px;margin-top:8px}
.tag{display:inline-flex;align-items:center;gap:7px;font-weight:600;font-size:13.5px;padding:7px 14px;border:1.5px solid var(--line-2);border-radius:var(--r-sm);background:#fff}.tag .c{color:var(--green);font-weight:700}
.note-card{background:var(--green-wash);border:1px solid var(--green-line);border-left:4px solid var(--green);border-radius:var(--r-lg);padding:18px 20px;margin-top:20px}.note-card b{color:var(--green-700)}
@media(max-width:820px){.buy-grid{grid-template-columns:1fr;gap:28px}}

/* steps */
.steps{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:8px}
.stepc{text-align:center;display:flex;flex-direction:column;align-items:center;position:relative}
.stepc::before{content:"";position:absolute;top:32px;right:50%;width:100%;height:2px;border-top:2px dashed var(--line-2);z-index:0}
.stepc:first-child::before{display:none}
.stepc .node{width:64px;height:64px;border-radius:50%;background:var(--grad-red);color:#fff;display:grid;place-items:center;font-family:var(--display);font-style:italic;font-weight:800;font-size:26px;position:relative;z-index:1;box-shadow:var(--e1)}
.stepc h3{font-style:italic;font-size:19px;margin:16px 0 8px}.stepc p{margin:0;max-width:32ch;color:var(--text-2);font-size:14.5px}
@media(max-width:760px){.steps{grid-template-columns:1fr;gap:22px;max-width:440px;margin:8px auto 0}.stepc{flex-direction:row;text-align:left;gap:18px;align-items:flex-start}.stepc::before{display:none}.stepc .node{flex:0 0 auto;width:54px;height:54px;font-size:22px}.stepc p{max-width:none}}

/* offer calc + scrap + checklist */
.split{display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:start}
.flist{list-style:none;margin:14px 0 0;padding:0;display:grid;gap:12px}
.flist li{display:flex;gap:12px;font-size:15px}.flist .n{font-family:var(--display);font-style:italic;font-weight:800;color:var(--red);flex:0 0 auto;font-size:16px}
.checklist{background:#fff;border:1px solid var(--line);border-radius:var(--r-lg);box-shadow:var(--e1);padding:26px}
.checklist h3{font-style:italic;font-size:20px;margin-bottom:6px}.checklist .subc{color:var(--text-2);font-size:14px;margin-bottom:16px}
.checklist ul{list-style:none;margin:0;padding:0;display:grid;gap:12px}
.checklist li{display:flex;gap:11px;font-size:15px;align-items:flex-start}
.checklist .ck{width:22px;height:22px;border-radius:var(--r-xs);border:2px solid var(--green);color:var(--green);display:grid;place-items:center;font-size:13px;font-weight:700;flex:0 0 auto;margin-top:1px}
.checklist .btn{margin-top:20px}
@media(max-width:820px){.split{grid-template-columns:1fr;gap:28px}}
.scrap{background:var(--ink);color:#fff;border-radius:var(--r-lg);padding:26px;box-shadow:var(--e2)}
.scrap h3{font-style:italic;font-size:20px;color:#fff}.scrap .subc{color:rgba(255,255,255,.66);font-size:13.5px;margin:4px 0 18px}
.tick{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
.chip{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.14);border-radius:var(--r-md);padding:14px}
.chip .m{font-size:12px;letter-spacing:.06em;text-transform:uppercase;color:rgba(255,255,255,.6)}
.chip .v{font-family:var(--display);font-style:italic;font-weight:800;font-size:24px;margin:4px 0 2px}
.chip .t{font-size:11.5px;font-family:var(--mono)}.chip .up{color:#56d08a}.chip .flat{color:var(--amber-300)}
.scrap .foot{margin-top:16px;font-size:12px;color:rgba(255,255,255,.5)}.scrap .foot a{color:rgba(255,255,255,.75);text-decoration:underline}
@media(max-width:620px){.tick{grid-template-columns:1fr}}

/* embedded form band */
.embed{background:var(--ink);color:#fff}
.embed.light{background:var(--blue-wash);color:var(--text)}
.embed .wrap{padding:42px 24px;display:grid;grid-template-columns:1fr 1fr;gap:36px;align-items:center}
.embed h3{font-style:italic;font-size:clamp(22px,2.6vw,28px);color:#fff}.embed.light h3{color:var(--text)}
.embed .ec p{color:rgba(255,255,255,.74);font-size:15px;margin:8px 0 0}.embed.light .ec p{color:var(--text-2)}
.embed form{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.embed .full{grid-column:1/-1}
.embed input,.embed select{height:48px;background:rgba(255,255,255,.08);border:1.5px solid rgba(255,255,255,.2);border-radius:var(--r-md);color:#fff;padding:0 13px;font-family:var(--body);font-size:14px;outline:none}
.embed.light input,.embed.light select{background:#fff;border-color:var(--line-2);color:var(--text)}
.embed input::placeholder{color:rgba(255,255,255,.55)}.embed.light input::placeholder{color:var(--text-3)}
.embed select{color:rgba(255,255,255,.62)}.embed.light select{color:var(--text-3)}.embed option{color:#111}
.embed input:focus,.embed select:focus{border-color:var(--amber)}
@media(max-width:780px){.embed .wrap{grid-template-columns:1fr;gap:22px}}

/* recently bought */
.deals{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
