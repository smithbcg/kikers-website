{"@type":"Question","name":"Do scrap prices really affect my offer?","acceptedAnswer":{"@type":"Answer","text":"Yes. Metals like copper, steel, and aluminum set the floor on a junk vehicle's value, and those prices move daily. When copper is strong, wiring and components are worth more."}},
{"@type":"Question","name":"How fast can you pick up my vehicle?","acceptedAnswer":{"@type":"Answer","text":"Often the same day. Or pick a time that works for you. Towing is free across the Pensacola area."}},
{"@type":"Question","name":"What areas do you serve?","acceptedAnswer":{"@type":"Answer","text":"We buy vehicles in Pensacola, Pace, Milton and East Milton, Cantonment, and nearby across Escambia and Santa Rosa counties."}}
]}
</script>

<script>
var nav=document.getElementById('nav');
function onScroll(){nav.classList.toggle('scrolled',window.scrollY>40);}
window.addEventListener('scroll',onScroll,{passive:true});onScroll();
var drawer=document.getElementById('drawer'),scrim=document.getElementById('scrim');
function openNav(){drawer.classList.add('open');scrim.classList.add('open');}
function closeNav(){drawer.classList.remove('open');scrim.classList.remove('open');}
document.getElementById('menuBtn').onclick=openNav;scrim.onclick=closeNav;
drawer.querySelectorAll('a').forEach(function(a){a.addEventListener('click',closeNav);});
(function(){var d=new Date().getDay();var now=new Date();var m=now.getHours()*60+now.getMinutes();var weekday=d>=1&&d<=5,sat=d===6;var open=(weekday&&m>=540&&m<990)||(sat&&m>=480&&m<840);var el=document.getElementById('openNow');if(el)el.textContent=open?'Open Today '+(sat?'8-2':'9-4:30'):(d===0?'Closed Sunday':'Closed - see posted hours');})();
function submitOffer(e){e.preventDefault();window.location.href='https://www.kikersautoparts.com/sell-a-vehicle';return false;}
var tHost=document.getElementById('toastHost');
function toast(msg){var t=document.createElement('div');t.className='toast';t.innerHTML='<span class="ic">✓</span>'+msg;tHost.appendChild(t);setTimeout(function(){t.style.opacity='0';t.style.transform='translateY(8px)';t.style.transition='opacity .2s,transform .2s';setTimeout(function(){t.remove();},220);},3400);}
</script>
